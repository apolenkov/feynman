{
  "mode": "yolo",
  "granularity": "coarse",
  "runtime": "claude",
  "parallelization": true,
  "commit_docs": true,
  "search_gitignored": false,
  "brave_search": false,
  "firecrawl": false,
  "exa_search": true,
  "model_profile": "balanced",
  "model_overrides": {
    "gsd-codebase-mapper": "haiku",
    "gsd-pattern-mapper": "haiku",
    "gsd-research-synthesizer": "haiku",
    "gsd-plan-checker": "haiku",
    "gsd-integration-checker": "haiku",
    "gsd-nyquist-auditor": "haiku",
    "gsd-ui-checker": "haiku",
    "gsd-ui-auditor": "haiku",
    "gsd-doc-verifier": "haiku",
    "gsd-phase-researcher": "sonnet",
    "gsd-project-researcher": "sonnet"
  },
  "model_profile_overrides": {
    "claude": {
      "opus": "claude-opus-4-7",
      "sonnet": "claude-sonnet-4-6",
      "haiku": "claude-haiku-4-5"
    },
    "codex": {
      "opus": "gpt-5.5",
      "sonnet": "gpt-5.3-codex",
      "haiku": "gpt-5.4-mini"
    }
  },
  "models": {
    "planning": "opus",
    "discuss": "opus",
    "research": "sonnet",
    "execution": "sonnet",
    "verification": "sonnet",
    "completion": "sonnet"
  },
  "dynamic_routing": {
    "enabled": true,
    "escalate_on_failure": true,
    "max_escalations": 1,
    "tier_models": {
      "light": "haiku",
      "standard": "sonnet",
      "heavy": "opus"
    }
  },
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "pattern_mapper": true,
    "nyquist_validation": true,
    "ui_phase": true,
    "ui_safety_gate": true,
    "tdd_mode": true,
    "code_review": true,
    "code_review_depth": "deep",
    "ui_review": true,
    "skip_discuss": false,
    "research_before_questions": true,
    "discuss_mode": "discuss",
    "text_mode": false,
    "auto_advance": false,
    "node_repair": true,
    "node_repair_budget": 3,
    "security_enforcement": true,
    "security_asvs_level": 1,
    "security_block_on": "high",
    "use_worktrees": false,
    "inline_plan_threshold": 0,
    "subagent_timeout": 600000,
    "auto_prune_state": false,
    "plan_bounce": false,
    "max_discuss_passes": 3,
    "cross_ai_execution": false,
    "ai_integration_phase": true,
    "post_planning_gaps": true,
    "_auto_chain_active": false
  },
  "git": {
    "branching_strategy": "none",
    "phase_branch_template": "gsd/phase-{phase}-{slug}",
    "milestone_branch_template": "gsd/{milestone}-{slug}",
    "quick_branch_template": null
  },
  "hooks": {
    "context_warnings": true
  },
